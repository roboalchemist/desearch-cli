.SH NAME
desearch-search - Search using Desearch AI


.SH SYNOPSIS
\fBdesearch search [query] [flags]\fP


.SH DESCRIPTION
Search the web using Desearch AI's contextual search engine.

.PP
Supports multiple sources including web, hackernews, reddit, wikipedia,
youtube, twitter, and arxiv. Results can be streamed in real-time or
returned as a complete response with AI summarization.


.SH OPTIONS
\fB--count\fP=0
	Number of results per source (10-200)

.PP
\fB--date-filter\fP=""
	Predefined date range (PAST_24_HOURS, PAST_2_DAYS, PAST_WEEK, PAST_2_WEEKS, PAST_MONTH, PAST_2_MONTHS, PAST_YEAR, PAST_2_YEARS)

.PP
\fB--dry-run\fP[=false]
	Build request and print as JSON without calling the API

.PP
\fB--end-date\fP=""
	End date in ISO8601 UTC format

.PP
\fB--fields\fP=""
	Comma-separated top-level JSON fields to include in output (requires --json)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for search

.PP
\fB--jq\fP=""
	jq expression to filter JSON output (requires --json or --no-ai)

.PP
\fB--no-ai\fP[=false]
	Skip AI completion/summary

.PP
\fB-p\fP, \fB--plaintext\fP[=false]
	Output as tab-separated values (title\\turl\\tsnippet)

.PP
\fB--result-type\fP=""
	Result type: ONLY_LINKS or LINKS_WITH_FINAL_SUMMARY (default LINKS_WITH_FINAL_SUMMARY)

.PP
\fB--start-date\fP=""
	Start date in ISO8601 UTC format

.PP
\fB--streaming\fP[=false]
	Stream results as they arrive

.PP
\fB--system-message\fP=""
	System message to influence AI behavior

.PP
\fB--tool\fP=[]
	Sources to query (web, hackernews, reddit, wikipedia, youtube, twitter, arxiv). Empty queries all.


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	API key for authentication (overrides config file)

.PP
\fB--config\fP=""
	config file path (default ~/.config/desearch-cli/config.toml)

.PP
\fB--json\fP[=false]
	Output in JSON format

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress stderr output except errors

.PP
\fB--silent\fP[=false]
	Suppress stderr output except errors (alias for --quiet)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show verbose progress output to stderr


.SH EXAMPLE
.EX
  desearch "golang best practices"
  desearch "rust vs go" --tool web --count 20
  desearch "AI news" --date-filter PAST_2_DAYS --streaming
.EE


