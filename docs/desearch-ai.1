.SH NAME
desearch-ai - Get an AI-generated summary without per-source results


.SH SYNOPSIS
\fBdesearch ai  [flags]\fP


.SH DESCRIPTION
Streams an AI-generated summary for the given query.

.PP
This command always streams results. It does not return per-source search results,
only the final AI summary.

.PP
Example:
  desearch ai "what is bittensor"
  desearch ai "explain transformers" --system-message "Summarize in simple terms"


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for ai

.PP
\fB--json\fP[=false]
	Output raw JSON response

.PP
\fB--system-message\fP=""
	Optional system message to override the default


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	API key for authentication (overrides config file)

.PP
\fB--config\fP=""
	config file path (default ~/.config/desearch-cli/config.toml)

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress stderr output except errors

.PP
\fB--silent\fP[=false]
	Suppress stderr output except errors (alias for --quiet)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show verbose progress output to stderr


.SH EXAMPLE
